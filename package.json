{
  "name": "us-county-merge",
  "version": "0.0.0",
  "license": "ISC",
  "description": "Provides an interface that uses US census county data to combine individual US counties into custom regions.",
  "author": "Philip Oriuwa",
  "private": true,
  "type": "module",
  "keywords": [
    "census-data",
    "us-counties",
    "geospatial",
    "custom-regions",
    "data-visualization",
    "population-aggregation",
    "gdp-aggregation",
    "geographic-data",
    "mapping",
    "region-builder"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build-county-data": "node ./scripts/build-county-data.mjs",
    "build-highway-data": "node ./scripts/build-highway-data.mjs",
    "build-map": "node ./scripts/generate-svg.mjs",
    "preview": "vite preview",
    "preview-map": "node --watch ./scripts/generate-svg.mjs"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "mapshaper": "^0.6.13",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "@panzoom/panzoom": "^4.6.2"
  }
}
